{
  "permissions": {
    "allow": [
      "Read(~/.gradle/**)",
      "Bash(ast-index:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cross-repo-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cross-repo-guard.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "ksrc@respawn-tools": true,
    "maven-mcp@krozov-ai-tools": true,
    "firebase@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "developer-workflow@krozov-ai-tools": true,
    "kotlin-lsp@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "ast-index@ast-index-marketplace": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "firebase@firebase": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ast-index-marketplace": {
      "source": {
        "source": "github",
        "repo": "defendend/Claude-ast-index-search"
      }
    },
    "krozov-ai-tools": {
      "source": {
        "source": "github",
        "repo": "kirich1409/krozov-ai-tools"
      }
    },
    "firebase": {
      "source": {
        "source": "github",
        "repo": "firebase/firebase-tools"
      }
    }
  },
  "language": "English",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
