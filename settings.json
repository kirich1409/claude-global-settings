  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-pull.sh"
          },
          {
            "type": "command",
            "command": "ast-index update >/dev/null 2>&1 || ast-index rebuild >/dev/null 2>&1; if ast-index stats >/dev/null 2>&1; then [ \"$(git rev-parse --show-toplevel 2>/dev/null)\" = \"$HOME/.claude\" ] || ( nohup ast-index watch >/dev/null 2>&1 & ); else echo '⚠ AST INDEX NOT AVAILABLE — run the matching ast-index:initialize-* skill before any code search'; fi",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree 2>/dev/null && { echo ''; echo '=== GIT STATE ==='; echo \"Current branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null)\"; git rev-parse --git-dir 2>/dev/null | grep -qE '/\\.git/worktrees/' && echo 'Is worktree: yes' || echo 'Is worktree: no'; DEFAULT=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||'); echo \"Default branch: ${DEFAULT:-(unknown -- run: git remote set-head origin --auto)}\"; echo 'Existing worktrees:'; git worktree list 2>/dev/null; echo 'Local feature branches:'; git branch 2>/dev/null | grep -vE '\\b(main|master|develop)\\b' | head -20; echo 'Remote feature branches:'; git branch -r 2>/dev/null | grep -vE '(\\b(main|master|develop)\\b|HEAD)' | head -10; echo '================='; echo ''; } || true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/krozov/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/ast-index-stop-watch.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/ast-index-bootstrap-worktree.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cross-repo-guard.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/branch-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cross-repo-guard.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/branch-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/stash-reminder.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
