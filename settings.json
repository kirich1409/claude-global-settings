      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(npm publish *)",
      "Bash(yarn publish *)",
      "Bash(docker push *)",
      "Bash(pod trunk push *)",
      "Bash(fastlane *)",
      "Bash(firebase deploy *)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-pull.sh"
          },
          {
            "type": "command",
            "command": "ast-index update 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree 2>/dev/null && { echo ''; echo '=== GIT STATE ==='; echo \"Current branch: $(git rev-parse --abbrev-ref HEAD 2>/dev/null)\"; git rev-parse --git-dir 2>/dev/null | grep -qE '/\\.git/worktrees/' && echo 'Is worktree: yes' || echo 'Is worktree: no'; DEFAULT=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||'); echo \"Default branch: ${DEFAULT:-(unknown -- run: git remote set-head origin --auto)}\"; echo 'Existing worktrees:'; git worktree list 2>/dev/null; echo 'Local feature branches:'; git branch 2>/dev/null | grep -vE '\\b(main|master|develop)\\b' | head -20; echo 'Remote feature branches:'; git branch -r 2>/dev/null | grep -vE '(\\b(main|master|develop)\\b|HEAD)' | head -10; echo '================='; echo ''; } || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,subprocess; d=json.load(sys.stdin); cmd=d.get('tool_input',{}).get('command',''); any(op in cmd for op in ['git pull','git checkout','git merge','git rebase','git stash']) and subprocess.run(['ast-index','update'],capture_output=True)\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cross-repo-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/cross-repo-guard.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
