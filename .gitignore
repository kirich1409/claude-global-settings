# Deny all by default
*

# === CONFIGURATION ===
!.gitignore
!README.md
!settings.json
!CLAUDE.md
!RTK.md

# === HOOKS ===
!hooks/
!hooks/**

# === AGENTS ===
!agents/
!agents/**
!agent-memory/
!agent-memory/**

# === SKILLS (local directories only, not symlinks) ===
!skills/
!skills/*/
!skills/*/*
!skills/*/**

# === PLUGIN MANIFESTS (not installed_plugins.json — it's a local cache) ===
!plugins/
!plugins/blocklist.json
!plugins/known_marketplaces.json

# === FORCE EXCLUDE (safety net) ===
.credentials.json
channels/
mcp-needs-auth-cache.json
credentials.md
*.jsonl

# === PROJECT-SPECIFIC SKILLS (not portable) ===
skills/databinding-to-viewbinding-workspace/
