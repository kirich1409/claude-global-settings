# Deny all by default
*

# === CONFIGURATION ===
!.gitignore
!README.md
!setup.sh
!settings.json
!CLAUDE.md
!RTK.md
!statusline-command.sh

# === RULES ===
!rules/
!rules/**

# === HOOKS ===
!hooks/
!hooks/**

# === AGENTS ===
!agents/
!agents/**
!agent-memory/
!agent-memory/**

# === SKILLS (local directories only, not symlinks) ===
!skills/
!skills/*/
!skills/*/*
!skills/*/**


# === FORCE EXCLUDE ===
.credentials.json
channels/
mcp-needs-auth-cache.json
credentials.md
*.jsonl
*.remote
swarm-report/
